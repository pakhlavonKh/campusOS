# ========================================
# CampusOS Environment Configuration
# ========================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=CampusOS
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL 16+)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=campusos
DATABASE_USER=campusos
DATABASE_PASSWORD=campusos_dev_password
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=30d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=campusos-uploads
S3_BUCKET_MEDIA=campusos-media
S3_REGION=us-east-1

# OpenSearch
OPENSEARCH_NODE=http://localhost:9200

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@campusos.dev

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
