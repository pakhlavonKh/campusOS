{
  "expo": {
    "name": "CampusOS",
    "slug": "campusos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "campusos",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campusos.mobile"
    },
    "android": {
      "package": "com.campusos.mobile",
      "permissions": ["DETECT_SCREEN_CAPTURE"]
    },
    "plugins": [
      ["expo-router", { "root": "src/app" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
