{
  "name": "@campusos/desktop",
  "version": "1.0.0",
  "description": "Desktop wrapper for CampusOS using Electron",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm run build && electron .",
    "build": "tsc && node -e \"require('fs').copyFileSync('src/offline.html', 'dist/offline.html')\"",
    "package": "electron-builder build --win --mac --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.campusos.desktop",
    "productName": "CampusOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education"
    }
  }
}
